{
  "blast_radius": {
    "$defs": {
      "EdgeKindFilter": {
        "description": "Edge-kind filter exposed to clients. Subset of the in-RAM graph\nalphabet — clients pick which edge classes the analytic walks.",
        "oneOf": [
          {
            "const": "calls",
            "description": "Call edges.",
            "type": "string"
          },
          {
            "const": "imports",
            "description": "Import edges.",
            "type": "string"
          },
          {
            "const": "type_of",
            "description": "Type-of edges.",
            "type": "string"
          },
          {
            "const": "defines",
            "description": "Definition edges.",
            "type": "string"
          },
          {
            "const": "overrides",
            "description": "Override edges.",
            "type": "string"
          },
          {
            "const": "reads",
            "description": "Read edges.",
            "type": "string"
          },
          {
            "const": "writes",
            "description": "Write edges.",
            "type": "string"
          },
          {
            "const": "inherits",
            "description": "Inheritance edges.",
            "type": "string"
          }
        ]
      }
    },
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "description": "Input to `blast_radius`.",
    "properties": {
      "depth": {
        "default": null,
        "description": "Reverse-BFS hop limit. Defaults to 3.",
        "format": "uint8",
        "maximum": 255,
        "minimum": 0,
        "type": [
          "integer",
          "null"
        ]
      },
      "kinds": {
        "default": null,
        "description": "Edge-kind filter set. Empty / missing = all kinds.",
        "items": {
          "$ref": "#/$defs/EdgeKindFilter"
        },
        "type": [
          "array",
          "null"
        ]
      },
      "symbol": {
        "description": "Target symbol canonical name.",
        "type": "string"
      }
    },
    "required": [
      "symbol"
    ],
    "title": "BlastRadiusInput",
    "type": "object"
  },
