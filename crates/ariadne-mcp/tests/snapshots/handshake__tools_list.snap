    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "description": "Input to `weak_spots` â€” a dedicated type (not the shared [`ScopeInput`]) so\nadding `limit`/`cursor`/`verbosity` here leaves the other `ScopeInput`\nconsumer (`doc_for_project`) untouched (Block 1, tier-03, mirroring\n[`CouplingInput`]).",
    "properties": {
      "cursor": {
        "description": "Opaque multi-list pagination cursor from a prior page; absent = first\npage.",
        "type": [
          "string",
          "null"
        ]
