{
  "affected_tests": {
    "$defs": {
      "DiffSpecInput": {
        "description": "Which changeset a `diff_blast_radius` query scopes (tier-15c D4). Mirrors\n`ariadne_core::DiffSpec` behind a `JsonSchema`-deriving input the MCP layer\nowns; the handler maps it to the core type (core stays a wire/domain type\nthat need not derive `schemars`). Defaults to the uncommitted working tree.",
        "oneOf": [
          {
            "const": "working_tree",
            "description": "Uncommitted index + worktree changes against `HEAD` (the default).",
            "type": "string"
          },
          {
            "additionalProperties": false,
            "description": "A single commit against its first parent; the string is a revspec\n(commit-ish) the git adapter resolves.",
            "properties": {
              "commit": {
                "type": "string"
              }
            },
            "required": [
              "commit"
            ],
            "type": "object"
          },
          {
            "additionalProperties": false,
            "description": "The diff between two resolved revisions, `from` (old) â†’ `to` (new); both\nstrings are revspecs the git adapter resolves.",
            "properties": {
              "ref_range": {
                "properties": {
                  "from": {
                    "description": "Old-side revspec.",
                    "type": "string"
                  },
                  "to": {
                    "description": "New-side revspec.",
                    "type": "string"
                  }
                },
                "required": [
                  "from",
                  "to"
                ],
                "type": "object"
              }
            },
            "required": [
              "ref_range"
            ],
            "type": "object"
          }
        ]
      },
      "EdgeKindFilter": {
        "description": "Edge-kind filter exposed to clients. Subset of the in-RAM graph\nalphabet â€” clients pick which edge classes the analytic walks.",
        "oneOf": [
          {
            "const": "calls",
            "description": "Call edges.",
            "type": "string"
          },
          {
            "const": "imports",
            "description": "Import edges.",
            "type": "string"
          },
          {
            "const": "type_of",
            "description": "Type-of edges.",
            "type": "string"
          },
          {
            "const": "defines",
            "description": "Definition edges.",
            "type": "string"
          },
          {
            "const": "overrides",
            "description": "Override edges.",
            "type": "string"
          },
          {
            "const": "reads",
            "description": "Read edges.",
            "type": "string"
          },
          {
            "const": "writes",
            "description": "Write edges.",
            "type": "string"
          },
          {
            "const": "inherits",
            "description": "Inheritance edges.",
            "type": "string"
          }
        ]
      },
      "Verbosity": {
        "description": "Field verbosity for a growable tool's rows (Block 1, tier-01 D3). Concise\n(the default) omits the cryptic id/offset fields the LLM reasons about\nworse; `detailed` is a lossless superset. Mirrors\n`ariadne_graph::economy::Verbosity` / `ariadne_core::Verbosity`; the server\nmaps between them (as it does for [`Grain`]).",
        "oneOf": [
          {
            "const": "concise",
            "description": "Omit cryptic id/offset fields (the default).",
            "type": "string"
          },
          {
            "const": "detailed",
            "description": "Emit every field â€” the lossless superset.",
            "type": "string"
          }
        ]
      }
    },
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "description": "Input to `affected_tests` â€” mirrors `diff_blast_radius` (the same changeset\n`spec` + reverse-reach `depth`/`kinds`), since A1 reuses the diffâ†’seedâ†’\nreverse-reach machinery (block-a plan.md D1). The `limit`/`cursor`/\n`verbosity` economy controls (Block 1, tier-04) cap `tests` / `seeds` behind\none diff-aware multi-list cursor.",
    "properties": {
      "cursor": {
        "description": "Opaque diff-aware multi-list cursor from a prior page; absent = first\npage. Rejected once the index revision or the changed-paths fingerprint\nchanges under it.",
        "type": [
          "string",
          "null"
        ]
      },
      "depth": {
        "default": null,
        "description": "Reverse-BFS hop limit per changed seed. Defaults to 3.",
        "format": "uint8",
        "maximum": 255,
        "minimum": 0,
        "type": [
          "integer",
          "null"
        ]
      },
      "kinds": {
        "default": null,
        "description": "Edge-kind filter set. Empty / missing = all kinds.",
        "items": {
          "$ref": "#/$defs/EdgeKindFilter"
        },
        "type": [
          "array",
          "null"
        ]
      },
      "limit": {
        "description": "Maximum rows per top-level sublist (tests / seeds); defaults to the\neconomy page size (50).",
        "format": "uint32",
        "minimum": 0,
        "type": [
          "integer",
          "null"
        ]
      },
      "spec": {
        "$ref": "#/$defs/DiffSpecInput",
        "default": "working_tree",
        "description": "Which changeset to scope. Defaults to the uncommitted working tree."
      },
      "verbosity": {
        "$ref": "#/$defs/Verbosity",
        "default": "concise",
        "description": "Field verbosity; defaults to concise (drops the rows' cryptic id/offset\nfields)."
      }
    },
    "title": "AffectedTestsInput",
    "type": "object"
  },
