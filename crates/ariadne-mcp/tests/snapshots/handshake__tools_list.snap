    "description": "Input to `search_code`. Generalises [`ListSymbolsInput`]: the name match\nis a case-insensitive substring by default, or a regular expression when\n`regex` is set, narrowed by optional `path` glob / `kind` / `lang` /\n`visibility` filters [src: tier-07 D8].",
    "properties": {
      "kind": {
        "default": null,
        "description": "Optional exact kind filter (e.g. `function`, `struct`).",
