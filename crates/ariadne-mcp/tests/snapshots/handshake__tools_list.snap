        "type": "string"
      }
    },
    "required": [
      "symbol"
    ],
    "title": "SymbolQuery",
    "type": "object"
  },
  "find_references": {
    "$defs": {
      "Verbosity": {
        "description": "Field verbosity for a growable tool's rows (Block 1, tier-01 D3). Concise\n(the default) omits the cryptic id/offset fields the LLM reasons about\nworse; `detailed` is a lossless superset. Mirrors\n`ariadne_graph::economy::Verbosity` / `ariadne_core::Verbosity`; the server\nmaps between them (as it does for [`Grain`]).",
        "oneOf": [
          {
            "const": "concise",
            "description": "Omit cryptic id/offset fields (the default).",
            "type": "string"
          },
          {
            "const": "detailed",
            "description": "Emit every field â€” the lossless superset.",
            "type": "string"
          }
        ]
      }
    },
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "description": "Input to `find_references` â€” a dedicated type (not the shared\n[`SymbolQuery`]) so adding `limit`/`cursor`/`verbosity` here leaves\n`find_definition`/`doc_for` untouched (tier-01).",
    "properties": {
      "cursor": {
        "description": "Opaque pagination cursor from a prior page; absent = first page.",
        "type": [
          "string",
          "null"
        ]
      },
      "limit": {
        "description": "Maximum rows in the page; defaults to the economy page size (50).",
        "format": "uint32",
        "minimum": 0,
        "type": [
          "integer",
          "null"
        ]
      },
      "symbol": {
        "description": "Canonical name of the referenced symbol.",
        "type": "string"
      },
      "verbosity": {
        "$ref": "#/$defs/Verbosity",
        "default": "concise",
        "description": "Field verbosity; defaults to concise."
      }
    },
    "required": [
      "symbol"
    ],
    "title": "FindReferencesInput",
    "type": "object"
  },
  "fitness_report": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "description": "Input to `fitness_report` (block A, A3). The tool takes no parameters: it\nreads the repo's `ariadne-fitness.toml` (ADR-0028) and runs the engine over\nthe indexed graph, so callers pass an empty `{}`.",
    "title": "FitnessReportInput",
    "type": "object"
  },
  "hotspots": {
    "$defs": {
      "Grain": {
        "description": "Grain a `hotspots` / `complexity` query ranks at (tier-15b D2). File grain\nrolls each file's symbols up to one row (complexity summed); symbol grain\nreturns one row per symbol. Defaults to `File`.",
        "oneOf": [
          {
            "const": "file",
            "description": "One row per file, complexity summed over its symbols.",
            "type": "string"
          },
          {
            "const": "symbol",
            "description": "One row per symbol, carrying its own complexity.",
            "type": "string"
          }
        ]
      },
      "Verbosity": {
        "description": "Field verbosity for a growable tool's rows (Block 1, tier-01 D3). Concise\n(the default) omits the cryptic id/offset fields the LLM reasons about\nworse; `detailed` is a lossless superset. Mirrors\n`ariadne_graph::economy::Verbosity` / `ariadne_core::Verbosity`; the server\nmaps between them (as it does for [`Grain`]).",
        "oneOf": [
          {
            "const": "concise",
            "description": "Omit cryptic id/offset fields (the default).",
            "type": "string"
          },
          {
            "const": "detailed",
            "description": "Emit every field â€” the lossless superset.",
            "type": "string"
          }
        ]
      }
    },
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "description": "Input to `hotspots` and `complexity` â€” a path-prefix scope, a grain, and the\neconomy page controls (Block 1, tier-02).",
    "properties": {
      "cursor": {
        "description": "Opaque pagination cursor from a prior page; absent = first page.",
        "type": [
          "string",
          "null"
        ]
      },
      "grain": {
        "$ref": "#/$defs/Grain",
        "default": "file",
        "description": "File (default) or symbol grain."
      },
      "limit": {
        "description": "Maximum rows in the page; defaults to the economy page size (50).",
        "format": "uint32",
        "minimum": 0,
        "type": [
          "integer",
          "null"
        ]
      },
      "prefix": {
        "default": null,
        "description": "Optional path-prefix filter (project-root-relative). Empty = all files.",
        "type": [
          "string",
          "null"
        ]
      },
      "verbosity": {
        "$ref": "#/$defs/Verbosity",
        "default": "concise",
        "description": "Field verbosity; defaults to concise (drops the embedded symbol's\ncryptic id/offset fields on symbol-grain rows)."
      }
    },
    "title": "GrainScopeInput",
    "type": "object"
  },
  "list_symbols": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "description": "Input to `list_symbols`.",
    "properties": {
      "kind": {
        "default": null,
        "description": "Optional kind filter.",
        "type": [
          "string",
          "null"
        ]
      },
      "limit": {
        "default": null,
        "description": "Maximum rows returned. Defaults to 64.",
        "format": "uint32",
        "minimum": 0,
        "type": [
          "integer",
          "null"
        ]
      },
      "query": {
        "default": "",
        "description": "Substring filter on canonical name (case-insensitive). Empty = no filter.",
        "type": "string"
      }
    },
    "title": "ListSymbolsInput",
    "type": "object"
  },
  "plan_assist": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "description": "Input to `plan_assist`.",
    "properties": {
      "max_files": {
        "default": null,
        "description": "Maximum file rows. Defaults to 16.",
        "format": "uint32",
        "minimum": 0,
        "type": [
          "integer",
          "null"
        ]
      },
      "symbol": {
        "description": "Target symbol canonical name.",
        "type": "string"
      }
    },
    "required": [
      "symbol"
    ],
    "title": "PlanAssistInput",
    "type": "object"
  },
  "project_status": {
    "properties": {},
    "type": "object"
  },
  "read_outline": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "description": "Input to `read_outline`. Names the file to project into a folded code\nskeleton (signatures + doc comments kept, bodies elided to a marker) plus a\nsymbol index, so a consumer expands only the bodies it needs via\n`read_symbol` [src: context-efficient-read plan.md D1/D2].",
    "properties": {
      "include_private": {
        "default": null,
        "description": "Keep non-public symbols (and their folded bodies). Defaults to `true`;\n`false` drops everything below `Public` from both skeleton and index.",
        "type": [
          "boolean",
          "null"
        ]
      },
      "path": {
        "description": "Project-root-relative path of the file to outline.",
        "type": "string"
      }
    },
    "required": [
      "path"
    ],
    "title": "ReadOutlineInput",
    "type": "object"
  },
  "read_symbol": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "description": "Input to `read_symbol`. Resolves a symbol to its defining span and reads\nthe live file under the catalog root, returning just that slice â€” `file`\ndisambiguates an overloaded name, `mode` selects how much to return, and\n`context_lines` widens the `context` mode [src: tier-08 D9].",
    "properties": {
      "context_lines": {
        "default": null,
        "description": "Lines of surrounding context for `context` mode. Defaults to 3.",
        "format": "uint32",
        "minimum": 0,
        "type": [
          "integer",
          "null"
        ]
      },
      "file": {
        "default": null,
        "description": "Optional defining-file path (project-root-relative) to pick one of\nseveral symbols sharing `symbol`. Omitted = the first match.",
        "type": [
          "string",
          "null"
        ]
      },
      "mode": {
        "default": null,
        "description": "How much to return: `signature` (the declaration line), `full` (the\nwhole defining span, the default), or `context` (Â±`context_lines`).",
        "type": [
          "string",
          "null"
        ]
      },
      "symbol": {
        "description": "Canonical name of the symbol to read.",
        "type": "string"
      }
    },
    "required": [
      "symbol"
    ],
    "title": "ReadSymbolInput",
    "type": "object"
  },
  "refactor_suggestions": {
    "$defs": {
      "Verbosity": {
        "description": "Field verbosity for a growable tool's rows (Block 1, tier-01 D3). Concise\n(the default) omits the cryptic id/offset fields the LLM reasons about\nworse; `detailed` is a lossless superset. Mirrors\n`ariadne_graph::economy::Verbosity` / `ariadne_core::Verbosity`; the server\nmaps between them (as it does for [`Grain`]).",
        "oneOf": [
          {
            "const": "concise",
            "description": "Omit cryptic id/offset fields (the default).",
            "type": "string"
          },
          {
            "const": "detailed",
            "description": "Emit every field â€” the lossless superset.",
            "type": "string"
          }
        ]
      }
    },
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "description": "Input to `refactor_suggestions` â€” a dedicated type (not the shared\n[`ScopeInput`]) so adding `limit`/`cursor`/`verbosity` here leaves the other\n`ScopeInput` consumer (`doc_for_project`) untouched (Block 1, tier-03,\nmirroring [`CouplingInput`]).",
    "properties": {
      "cursor": {
        "description": "Opaque multi-list pagination cursor from a prior page; absent = first\npage.",
        "type": [
          "string",
          "null"
        ]
      },
      "limit": {
        "description": "Maximum rows per sublist; defaults to the economy page size (50).",
        "format": "uint32",
        "minimum": 0,
        "type": [
          "integer",
          "null"
        ]
      },
      "prefix": {
        "default": null,
        "description": "Optional path-prefix filter (project-root-relative). Empty = all files.",
        "type": [
          "string",
          "null"
        ]
      },
      "verbosity": {
        "$ref": "#/$defs/Verbosity",
        "default": "concise",
        "description": "Field verbosity; defaults to concise (a no-op â€” every refactor row is\nname/metric only, so concise == detailed)."
      }
    },
    "title": "RefactorInput",
    "type": "object"
  },
  "search_code": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "description": "Input to `search_code`. Generalises [`ListSymbolsInput`]: the name match\nis a case-insensitive substring by default, or a regular expression when\n`regex` is set, narrowed by optional `path` glob / `kind` / `lang` /\n`visibility` filters [src: tier-07 D8].",
    "properties": {
      "kind": {
        "default": null,
        "description": "Optional exact kind filter (e.g. `function`, `struct`).",
        "type": [
          "string",
          "null"
        ]
      },
      "lang": {
        "default": null,
        "description": "Optional language-tag filter (e.g. `rust`, `typescript`).",
        "type": [
          "string",
          "null"
        ]
      },
      "limit": {
        "default": null,
        "description": "Maximum rows returned. Defaults to 64.",
        "format": "uint32",
        "minimum": 0,
        "type": [
          "integer",
          "null"
        ]
      },
      "path": {
        "default": null,
        "description": "Optional Unix glob the defining file path must match (e.g.\n`src/**/*.rs`).",
        "type": [
          "string",
          "null"
        ]
      },
      "query": {
        "default": "",
        "description": "Name pattern. A case-insensitive substring of the canonical name by\ndefault; a regular expression when `regex` is true. Empty = no name\nfilter.",
        "type": "string"
      },
      "regex": {
        "default": false,
        "description": "Treat `query` as a regular expression instead of a substring.",
        "type": "boolean"
      },
      "visibility": {
        "default": null,
        "description": "Optional visibility filter (`public`, `restricted`, `private`,\n`unknown`).",
        "type": [
          "string",
          "null"
        ]
      }
    },
    "title": "SearchCodeInput",
    "type": "object"
  },
  "weak_spots": {
    "$defs": {
      "Verbosity": {
        "description": "Field verbosity for a growable tool's rows (Block 1, tier-01 D3). Concise\n(the default) omits the cryptic id/offset fields the LLM reasons about\nworse; `detailed` is a lossless superset. Mirrors\n`ariadne_graph::economy::Verbosity` / `ariadne_core::Verbosity`; the server\nmaps between them (as it does for [`Grain`]).",
