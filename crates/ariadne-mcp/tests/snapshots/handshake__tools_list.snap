  "read_symbol": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "description": "Input to `read_symbol`. Resolves a symbol to its defining span and reads\nthe live file under the catalog root, returning just that slice — `file`\ndisambiguates an overloaded name, `mode` selects how much to return, and\n`context_lines` widens the `context` mode [src: tier-08 D9].",
    "properties": {
      "context_lines": {
        "default": null,
        "description": "Lines of surrounding context for `context` mode. Defaults to 3.",
        "format": "uint32",
        "minimum": 0,
        "type": [
          "integer",
          "null"
        ]
      },
      "file": {
        "default": null,
        "description": "Optional defining-file path (project-root-relative) to pick one of\nseveral symbols sharing `symbol`. Omitted = the first match.",
        "type": [
          "string",
          "null"
        ]
      },
      "mode": {
        "default": null,
        "description": "How much to return: `signature` (the declaration line), `full` (the\nwhole defining span, the default), or `context` (±`context_lines`).",
        "type": [
          "string",
          "null"
        ]
      },
      "symbol": {
        "description": "Canonical name of the symbol to read.",
        "type": "string"
      }
    },
    "required": [
      "symbol"
    ],
    "title": "ReadSymbolInput",
    "type": "object"
