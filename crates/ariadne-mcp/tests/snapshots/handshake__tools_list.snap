{
  "blast_radius": {
    "$defs": {
      "EdgeKindFilter": {
        "description": "Edge-kind filter exposed to clients. Subset of the in-RAM graph\nalphabet — clients pick which edge classes the analytic walks.",
        "oneOf": [
          {
            "const": "calls",
            "description": "Call edges.",
            "type": "string"
          },
          {
            "const": "imports",
            "description": "Import edges.",
            "type": "string"
          },
          {
            "const": "type_of",
            "description": "Type-of edges.",
            "type": "string"
          },
          {
            "const": "defines",
            "description": "Definition edges.",
            "type": "string"
          },
          {
            "const": "overrides",
            "description": "Override edges.",
            "type": "string"
          },
          {
            "const": "reads",
            "description": "Read edges.",
            "type": "string"
          },
          {
            "const": "writes",
            "description": "Write edges.",
            "type": "string"
          },
          {
            "const": "inherits",
            "description": "Inheritance edges.",
            "type": "string"
          }
        ]
      }
    },
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "description": "Input to `blast_radius`.",
    "properties": {
      "depth": {
        "default": null,
        "description": "Reverse-BFS hop limit. Defaults to 3.",
        "format": "uint8",
        "maximum": 255,
        "minimum": 0,
        "type": [
          "integer",
          "null"
        ]
      },
      "kinds": {
        "default": null,
        "description": "Edge-kind filter set. Empty / missing = all kinds.",
        "items": {
          "$ref": "#/$defs/EdgeKindFilter"
        },
        "type": [
          "array",
          "null"
        ]
      },
      "symbol": {
        "description": "Target symbol canonical name.",
        "type": "string"
      }
    },
    "required": [
      "symbol"
    ],
    "title": "BlastRadiusInput",
    "type": "object"
  },
  "co_change": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "description": "Input to `co_change`. The three optional thresholds default to code-maat's\npublished values (`min_revs = 5`, `min_shared_commits = 5`,\n`min_degree = 0.30`) when omitted.",
    "properties": {
      "min_degree": {
        "default": null,
        "description": "Minimum coupling degree ∈ [0, 1]. Defaults to 0.30.",
        "format": "float",
        "type": [
          "number",
          "null"
        ]
      },
      "min_revs": {
        "default": null,
        "description": "Minimum individual revisions per endpoint. Defaults to 5.",
        "format": "uint32",
        "minimum": 0,
        "type": [
          "integer",
          "null"
        ]
      },
      "min_shared_commits": {
        "default": null,
        "description": "Minimum shared-commit support per pair. Defaults to 5.",
        "format": "uint32",
        "minimum": 0,
        "type": [
          "integer",
          "null"
        ]
      },
      "prefix": {
        "default": null,
        "description": "Optional path-prefix scope: keeps an edge when either endpoint path is\nin scope (project-root-relative). Empty = all files.",
        "type": [
          "string",
          "null"
        ]
      }
    },
    "title": "CoChangeInput",
    "type": "object"
  },
  "complexity": {
    "$defs": {
      "Grain": {
        "description": "Grain a `hotspots` / `complexity` query ranks at (tier-15b D2). File grain\nrolls each file's symbols up to one row (complexity summed); symbol grain\nreturns one row per symbol. Defaults to `File`.",
        "oneOf": [
          {
            "const": "file",
            "description": "One row per file, complexity summed over its symbols.",
            "type": "string"
          },
          {
            "const": "symbol",
            "description": "One row per symbol, carrying its own complexity.",
            "type": "string"
          }
        ]
      }
    },
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "description": "Input to `hotspots` and `complexity` — a path-prefix scope and a grain.",
    "properties": {
      "grain": {
        "$ref": "#/$defs/Grain",
        "default": "file",
        "description": "File (default) or symbol grain."
      },
      "prefix": {
        "default": null,
        "description": "Optional path-prefix filter (project-root-relative). Empty = all files.",
        "type": [
          "string",
          "null"
        ]
      }
    },
    "title": "GrainScopeInput",
    "type": "object"
  },
  "coupling_report": {
