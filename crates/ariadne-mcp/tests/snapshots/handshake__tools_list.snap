      "limit": {
        "description": "Maximum rows per sublist; defaults to the economy page size (50).",
        "format": "uint32",
        "minimum": 0,
        "type": [
          "integer",
          "null"
        ]
      },
      "prefix": {
        "default": null,
        "description": "Optional path-prefix filter (project-root-relative). Empty = all files.",
        "type": [
          "string",
          "null"
        ]
      },
      "verbosity": {
        "$ref": "#/$defs/Verbosity",
        "default": "concise",
        "description": "Field verbosity; defaults to concise (drops the dead-symbol rows' cryptic\nid/offset fields; cycle / god-module rows carry none, so concise ==\ndetailed for them)."
