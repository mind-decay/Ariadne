        "description": "Optional language-tag filter (e.g. `rust`, `typescript`).",
        "type": [
          "string",
          "null"
        ]
      },
      "limit": {
        "default": null,
        "description": "Maximum rows returned. Defaults to 64.",
        "format": "uint32",
        "minimum": 0,
        "type": [
          "integer",
          "null"
        ]
      },
      "path": {
        "default": null,
        "description": "Optional Unix glob the defining file path must match (e.g.\n`src/**/*.rs`).",
        "type": [
          "string",
          "null"
        ]
      },
      "query": {
        "default": "",
        "description": "Name pattern. A case-insensitive substring of the canonical name by\ndefault; a regular expression when `regex` is true. Empty = no name\nfilter.",
        "type": "string"
      },
      "regex": {
        "default": false,
        "description": "Treat `query` as a regular expression instead of a substring.",
        "type": "boolean"
      },
      "visibility": {
        "default": null,
        "description": "Optional visibility filter (`public`, `restricted`, `private`,\n`unknown`).",
        "type": [
          "string",
          "null"
        ]
      }
    },
    "title": "SearchCodeInput",
    "type": "object"
  },
